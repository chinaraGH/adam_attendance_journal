## Auth (optional for local dev; a safe default exists, but set in production)
AUTH_SECRET=""
TEST_PASSWORD="test"

## Cron endpoint protection (required if you call /api/cron/*)
CRON_SECRET=""

## Sync endpoint protection (required if you use sync endpoints)
SYNC_SECRET=""
