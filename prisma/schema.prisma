generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Faculty {
  id        String    @id @default(cuid())
  name      String
  code      String?   @unique
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  programs Program[]

  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("faculties")
}

model Program {
  id        String    @id @default(cuid())
  facultyId String    @map("faculty_id")
  name      String
  code      String?   @unique
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  faculty     Faculty     @relation(fields: [facultyId], references: [id])
  groups      Group[]
  disciplines Discipline[]

  @@index([facultyId])
  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("programs")
}

model Discipline {
  id        String    @id @default(cuid())
  programId String?   @map("program_id")
  name      String
  code      String?   @unique
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  program       Program?      @relation(fields: [programId], references: [id])
  classSessions ClassSession[]

  @@index([programId])
  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("disciplines")
}

model Teacher {
  // Use same ID space as `User` for now (mock auth uses userId like TEACHER_TEST).
  id        String    @id
  gaudiId   String?   @unique @map("gaudi_id")
  name      String
  email     String?
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  classSessions ClassSession[]

  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("teachers")
}

model Group {
  id        String    @id @default(cuid())
  gaudiId   String    @unique @map("gaudi_id")
  programId String?   @map("program_id")
  name      String
  code      String?
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  program Program? @relation(fields: [programId], references: [id])
  students      Student[]
  classSessions ClassSession[]
  curatorLinks  UserGroupCurator[]

  @@index([programId])
  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("groups")
}

model User {
  id        String   @id
  role      String   @map("role")
  isActive  Boolean  @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  curatorGroups UserGroupCurator[]

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model UserGroupCurator {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  groupId   String   @map("group_id")
  isActive  Boolean  @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("user_group_curators")
}

model Student {
  id        String    @id @default(cuid())
  gaudiId   String    @unique @map("gaudi_id")
  groupId   String    @map("group_id")
  name      String
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  group       Group        @relation(fields: [groupId], references: [id])
  attendances Attendance[]

  @@index([groupId])
  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("students")
}

model ClassSession {
  id                   String    @id @default(cuid())
  scheduleExternalId   String    @unique @map("schedule_external_id")
  gaudiId              String?   @unique @map("gaudi_id")
  disciplineId         String    @map("discipline_id")
  groupId              String    @map("group_id")
  teacherId            String    @map("teacher_id")
  semesterId           String    @map("semester_id")
  startTime            DateTime  @map("start_time")
  endTime              DateTime  @map("end_time")
  status               String    @default("scheduled")
  // Soft migration status field (enums not supported by current SQLite connector).
  statusV2             String?   @map("status_v2")
  openedAt             DateTime? @map("opened_at")
  flagLateTeacher      Boolean   @default(false) @map("flag_late_teacher")
  isActive             Boolean   @default(true) @map("is_active")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  discipline  Discipline   @relation(fields: [disciplineId], references: [id])
  group       Group        @relation(fields: [groupId], references: [id])
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  semester    Semester?    @relation(fields: [semesterId], references: [id])
  attendances Attendance[]

  @@index([disciplineId])
  @@index([groupId])
  @@index([groupId, startTime])
  @@index([teacherId])
  @@index([semesterId])
  @@index([startTime])
  @@index([endTime])
  @@index([status])
  @@index([statusV2])
  @@index([updatedAt])
  @@index([isActive])
  @@index([deletedAt])
  @@map("class_sessions")
}

model Attendance {
  id             String    @id @default(cuid())
  classSessionId String    @map("class_session_id")
  studentId      String    @map("student_id")
  semesterId     String    @map("semester_id")
  status         String?
  // Soft migration status field (enums not supported by current SQLite connector).
  statusV2       String?   @map("status_v2")
  gaudiId        String?   @unique @map("gaudi_id")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  updatedBy      String?   @map("updated_by")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  classSession ClassSession @relation(fields: [classSessionId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  semester     Semester     @relation(fields: [semesterId], references: [id])

  @@unique([classSessionId, studentId])
  @@index([studentId])
  @@index([classSessionId])
  @@index([studentId, classSessionId])
  @@index([semesterId])
  @@index([status])
  @@index([statusV2])
  @@index([updatedAt])
  @@index([classSessionId, status])
  @@index([isActive])
  @@index([deletedAt])
  @@map("attendances")
}

model IntegrationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  provider  String   @map("provider") // "gaudi" | "schedule"
  status    String   @map("status")   // "success" | "error"

  details   Json?    @map("details") // summary/errors payload

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@map("integration_logs")
}

model Semester {
  id        String    @id @default(cuid())
  name      String?
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  isLocked  Boolean   @default(false) @map("is_locked")
  lockedAt  DateTime? @map("locked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  classSessions ClassSession[]
  attendances   Attendance[]

  @@index([startDate])
  @@index([endDate])
  @@index([isLocked])
  @@map("semesters")
}

model AuditTrail {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  actorType String   @map("actor_type")
  actorId   String?  @map("actor_id")

  action     String @map("action")
  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  // Store JSON as string (Prisma Json not supported by current SQLite connector).
  beforeJson String? @map("before_json")
  afterJson  String? @map("after_json")

  @@index([createdAt])
  @@index([actorType, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@map("audit_trail")
}
