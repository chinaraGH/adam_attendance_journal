generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Faculty {
  id          String       @id @default(cuid())
  name        String
  code        String?      @unique
  isActive    Boolean      @default(true) @map("is_active")
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  departments Department[]
  programs    Program[]

  @@map("faculties")
}

model Department {
  id          String       @id @default(cuid())
  facultyId   String       @map("faculty_id")
  name        String
  code        String?
  isActive    Boolean      @default(true) @map("is_active")
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  faculty     Faculty      @relation(fields: [facultyId], references: [id])
  disciplines Discipline[]
  programs    Program[]

  @@unique([facultyId, name])
  @@map("departments")
}

model Program {
  id              String              @id @default(cuid())
  facultyId       String              @map("faculty_id")
  departmentId    String              @map("department_id")
  name            String
  code            String?
  isActive        Boolean             @default(true) @map("is_active")
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  disciplineLinks DisciplineProgram[]
  groups          Group[]
  department      Department          @relation(fields: [departmentId], references: [id])
  faculty         Faculty             @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, departmentId, name], map: "programs_faculty_department_name_key")
  @@map("programs")
}

model Discipline {
  id            String              @id @default(cuid())
  departmentId  String?             @map("department_id")
  name          String
  code          String?             @unique
  isActive      Boolean             @default(true) @map("is_active")
  deletedAt     DateTime?           @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  classSessions ClassSession[]
  programLinks  DisciplineProgram[]
  department    Department?         @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, name], map: "disciplines_department_name_key")
  @@index([departmentId])
  @@map("disciplines")
}

model DisciplineProgram {
  id           String     @id @default(cuid())
  disciplineId String     @map("discipline_id")
  programId    String     @map("program_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  discipline   Discipline @relation(fields: [disciplineId], references: [id])
  program      Program    @relation(fields: [programId], references: [id])

  @@unique([disciplineId, programId], map: "discipline_programs_discipline_program_key")
  @@index([disciplineId])
  @@index([programId])
  @@map("discipline_programs")
}

model Teacher {
  id            String         @id
  gaudiId       String?        @unique @map("gaudi_id")
  name          String
  email         String?
  isActive      Boolean        @default(true) @map("is_active")
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  classSessions ClassSession[]

  @@map("teachers")
}

model Group {
  id            String             @id @default(cuid())
  gaudiId       String             @unique @map("gaudi_id")
  programId     String?            @map("program_id")
  name          String
  code          String?
  isActive      Boolean            @default(true) @map("is_active")
  deletedAt     DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  classSessions ClassSession[]
  program       Program?           @relation(fields: [programId], references: [id])
  students      Student[]
  curatorLinks  UserGroupCurator[]

  @@unique([programId, code], map: "groups_program_code_key")
  @@index([programId])
  @@map("groups")
}

model AppUser {
  id            String             @id
  role          String             @map("role")
  isActive      Boolean            @default(true) @map("is_active")
  deletedAt     DateTime?          @map("deleted_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  curatorGroups UserGroupCurator[]

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model UserGroupCurator {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  groupId   String    @map("group_id")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  group     Group     @relation(fields: [groupId], references: [id])
  user      AppUser   @relation(fields: [userId], references: [id])

  @@unique([userId, groupId], map: "user_group_curators_user_group_key")
  @@index([userId])
  @@index([groupId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("user_group_curators")
}

model Student {
  id          String       @id @default(cuid())
  gaudiId     String       @unique @map("gaudi_id")
  groupId     String       @map("group_id")
  name        String
  isActive    Boolean      @default(true) @map("is_active")
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  attendances Attendance[]
  group       Group        @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@map("students")
}

model ClassSession {
  id                 String       @id @default(cuid())
  scheduleExternalId String       @unique @map("schedule_external_id")
  gaudiId            String?      @unique @map("gaudi_id")
  disciplineId       String       @map("discipline_id")
  groupId            String       @map("group_id")
  teacherId          String       @map("teacher_id")
  semesterId         String       @map("semester_id")
  startTime          DateTime     @map("start_time") @db.Timestamptz(6)
  endTime            DateTime     @map("end_time") @db.Timestamptz(6)
  status             String       @default("scheduled")
  statusV2           String?      @map("status_v2")
  openedAt           DateTime?    @map("opened_at") @db.Timestamptz(6)
  flagLateTeacher    Boolean      @default(false) @map("flag_late_teacher")
  isActive           Boolean      @default(true) @map("is_active")
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  attendances        Attendance[]
  discipline         Discipline   @relation(fields: [disciplineId], references: [id])
  group              Group        @relation(fields: [groupId], references: [id])
  semester           Semester     @relation(fields: [semesterId], references: [id])
  teacher            Teacher      @relation(fields: [teacherId], references: [id])

  @@map("class_sessions")
}

model Attendance {
  id             String       @id @default(cuid())
  classSessionId String       @map("class_session_id")
  studentId      String       @map("student_id")
  semesterId     String       @map("semester_id")
  status         String?
  statusV2       String?      @map("status_v2")
  gaudiId        String?      @unique @map("gaudi_id")
  isActive       Boolean      @default(true) @map("is_active")
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(6)
  updatedBy      String?      @map("updated_by")
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  classSession   ClassSession @relation(fields: [classSessionId], references: [id])
  semester       Semester     @relation(fields: [semesterId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])

  @@unique([classSessionId, studentId])
  @@map("attendances")
}

model IntegrationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  provider  String   @map("provider")
  status    String   @map("status")
  details   Json?    @map("details")

  @@map("integration_logs")
}

model Semester {
  id            String         @id @default(cuid())
  name          String?
  startDate     DateTime       @map("start_date") @db.Timestamptz(6)
  endDate       DateTime       @map("end_date") @db.Timestamptz(6)
  isLocked      Boolean        @default(false) @map("is_locked")
  lockedAt      DateTime?      @map("locked_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  attendances   Attendance[]
  classSessions ClassSession[]

  @@map("semesters")
}

model AuditTrail {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actorType  String   @map("actor_type")
  actorId    String?  @map("actor_id")
  action     String   @map("action")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  beforeJson String?  @map("before_json")
  afterJson  String?  @map("after_json")

  @@map("audit_trail")
}
